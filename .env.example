# Skopiuj ten plik do .env.local i uzupełnij wartościami z projektu Supabase
# (Supabase → Project Settings → API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Szybkie logowanie dla preview/dev (omija kod e-mail). Gdy ustawione, na ekranie
# logowania pojawia się przycisk „Szybkie logowanie (dev)", który loguje hasłem
# do testowego konta. USTAW TYLKO w środowisku Preview (i lokalnie) — NIGDY na
# produkcji. Wymaga utworzenia konta z hasłem w Supabase (Auth → Users → Add user).
NEXT_PUBLIC_DEV_EMAIL=
NEXT_PUBLIC_DEV_PASSWORD=
