# Skopiuj ten plik do .env.local i uzupełnij wartościami z projektu Supabase
# (Supabase → Project Settings → API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web Push (powiadomienia o nowych wypadach). Klucz PUBLICZNY pary VAPID.
# Wygeneruj parę: `npx web-push generate-vapid-keys` (publiczny tu, prywatny jako
# sekret Edge Function VAPID_PRIVATE_KEY). Bez tego przełącznik powiadomień się nie pokaże.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
